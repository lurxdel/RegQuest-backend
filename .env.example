#core settings
# Generate a new secret key for production using:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-goes-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.com,api.yourdomain.com

#middleware
DJANGO_CORS_ALLOWED_ORIGINS=https://yourfrontend.com,https://www.yourfrontend.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourfrontend.com,https://www.yourfrontend.com

#database and auth
# Provide a URL for Postgres, MySQL, etc. in production
DATABASE_URL=postgres://user:password@hostname:5432/dbname
DJANGO_JWT_SIGNING_KEY=your-production-dedicated-jwt-secret

# Production Overrides
# Force HTTPS and Secure Cookies in Production
DJANGO_SECURE_SSL_REDIRECT=True
# Future Services (Channels / Caching)
REDIS_URL=redis://your-redis-server:6379/1


# Initial Admin Seeder (Use only during initial deployment)
# INITIAL_ADMIN_EMAIL=admin@example.com
# INITIAL_ADMIN_USERNAME=superadmin
# INITIAL_ADMIN_PASSWORD=change_me_in_production